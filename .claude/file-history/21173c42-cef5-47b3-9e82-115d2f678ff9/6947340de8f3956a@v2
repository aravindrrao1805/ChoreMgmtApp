@import 'react-big-calendar/lib/css/react-big-calendar.css';

*, *::before, *::after { box-sizing: border-box; }

body {
  margin: 0;
  font-family: system-ui, -apple-system, sans-serif;
  background: #f0f2f5;
  color: #222;
}

/* ── App layout ── */
.app {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  background: #fff;
  border-bottom: 1px solid #e0e0e0;
  flex-shrink: 0;
}

.app-header h1 {
  margin: 0;
  font-size: 20px;
  font-weight: 700;
  color: #2d3a8c;
}

.app-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ── Member panel ── */
.member-panel {
  width: 220px;
  flex-shrink: 0;
  background: #fff;
  border-right: 1px solid #e0e0e0;
  padding: 16px 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow-y: auto;
}

.member-panel h3 {
  margin: 0 0 8px 0;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #666;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 5px 6px;
  border-radius: 6px;
  background: #f8f8f8;
}

.member-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.member-name {
  flex: 1;
  font-size: 14px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-remove {
  background: none;
  border: none;
  cursor: pointer;
  color: #bbb;
  font-size: 12px;
  padding: 0 2px;
  line-height: 1;
}
.member-remove:hover { color: #e07b54; }

.add-member-form {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}
.add-member-form input {
  flex: 1;
  padding: 5px 8px;
  border: 1px solid #ddd;
  border-radius: 5px;
  font-size: 13px;
}

.empty-hint {
  font-size: 13px;
  color: #aaa;
  margin: 0;
}

/* ── Calendar area ── */
.calendar-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 16px;
  overflow: hidden;
}

.calendar-wrapper {
  flex: 1;
  background: #fff;
  border-radius: 8px;
  border: 1px solid #e0e0e0;
  padding: 12px;
  overflow: hidden;
}

/* react-big-calendar overrides */
.rbc-event {
  padding: 0 !important;
  background: transparent !important;
  border: none !important;
}

.rbc-event.rbc-selected {
  background: transparent !important;
}

.rbc-day-slot .rbc-event {
  border: none !important;
}

/* ── Buttons ── */
.btn-primary {
  background: #2d3a8c;
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 8px 16px;
  font-size: 14px;
  cursor: pointer;
  font-weight: 500;
}
.btn-primary:hover { background: #3d4eaa; }

.btn-secondary {
  background: #f0f0f0;
  color: #333;
  border: 1px solid #ddd;
  border-radius: 6px;
  padding: 8px 16px;
  font-size: 14px;
  cursor: pointer;
}
.btn-secondary:hover { background: #e5e5e5; }

.btn-danger {
  background: #e53e3e;
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 8px 16px;
  font-size: 14px;
  cursor: pointer;
}
.btn-danger:hover { background: #c53030; }

.btn-sm {
  padding: 5px 10px;
  font-size: 13px;
}

/* ── Modal ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-box {
  background: #fff;
  border-radius: 10px;
  width: 440px;
  max-width: 95vw;
  padding: 24px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}

.modal-header h2 {
  margin: 0;
  font-size: 18px;
  font-weight: 700;
}

.modal-close {
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: #888;
  line-height: 1;
  padding: 0;
}
.modal-close:hover { color: #333; }

/* ── Chore form ── */
.chore-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.field label {
  font-size: 13px;
  font-weight: 600;
  color: #555;
}

.field input,
.field select {
  padding: 7px 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
}

.field-row {
  display: flex;
  gap: 12px;
}
.field-row .field { flex: 1; }

.day-checkboxes {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.day-check {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 13px;
  cursor: pointer;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 4px;
}

.form-actions .btn-danger {
  margin-right: auto;
}
